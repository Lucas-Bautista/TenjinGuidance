# Copy this file to .env and fill in values. Never commit .env.
#
#   cp .env.example .env

# Required for guided mode (LLM prompts in src/prompt.py).
ANTHROPIC_API_KEY=

# Optional: set to 1 to run live LLM tests (tests/test_fn_return_prompt_effectiveness.py).
# TRACTOR_RUN_LIVE_LLM=0

# --- libclang (C static analysis) — usually auto-detected ---
# Directory containing libclang.so (Linux) or libclang.dylib (macOS).
# LIBCLANG_PATH=/usr/lib/llvm-18/lib

# Optional: clang -resource-dir for parsing (Linux; auto-detected from `clang` if unset).
# CLANG_RESOURCE_DIR=
